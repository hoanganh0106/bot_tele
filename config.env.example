# ============================================
# CẤU HÌNH BOT BÁN CTV - ĐIỀN THÔNG TIN VÀO ĐÂY
# ============================================

# ---------- TELEGRAM BOT ----------
# Lấy token từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Telegram User ID của admin (để quản lý bot, sửa giá)
# Lấy bằng cách gửi tin nhắn cho @userinfobot
ADMIN_TELEGRAM_IDS=YOUR_ADMIN_TELEGRAM_ID

# ---------- CTV API (ĐỐI TÁC 1) ----------
# API key lấy từ bot @longdt8386_bot, gõ /ctv
CTV_API_URL=http://103.69.87.202:5000
CTV_API_KEY=YOUR_CTV_API_KEY

# ---------- HYPERVIN API (ĐỐI TÁC 3) ----------
HYPERVIN_API_URL=https://hypervin.xyz
HYPERVIN_API_KEY=YOUR_HYPERVIN_API_KEY
# Set 0 to disable low-balance alerts.
HYPERVIN_LOW_BALANCE_ALERT=50000

# ---------- CRM API (ĐỐI TÁC 2) ----------
CRMTEACHER_API_URL=https://api.crmteacher.org/openapi/v1
CRMTEACHER_API_KEY=YOUR_CRMTEACHER_API_KEY

# ---------- SEPAY WEBHOOK ----------
# Webhook port cho Flask server nhận thanh toán SePay
WEBHOOK_PORT=8443
# Domain/IP EC2 của bạn
WEBHOOK_HOST=http://YOUR_VPS_IP

# Để trống vì SePay đã chọn "Không cần chứng thực"
SEPAY_API_KEY=

# ---------- THANH TOÁN NGÂN HÀNG ----------
# Thông tin ngân hàng hiển thị cho khách chuyển khoản
BANK_NAME=VPBank
BANK_ACCOUNT_NUMBER=YOUR_BANK_ACCOUNT_NUMBER
BANK_ACCOUNT_NAME=YOUR_BANK_ACCOUNT_NAME
BANK_BIN=970432

# ---------- BINANCE USDT (CRYPTO) ----------
# API key chỉ bật "Enable Reading"; KHÔNG bật withdraw hoặc trade.
BINANCE_API_KEY=YOUR_BINANCE_API_KEY
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET

# UID Binance để khách chuyển nội bộ qua Binance Pay (tùy chọn, chỉ hiển thị cho khách).
BINANCE_PAY_UID=

# Địa chỉ nạp USDT Binance qua BNB Smart Chain.
USDT_WALLET_ADDRESS=YOUR_USDT_BEP20_ADDRESS
USDT_NETWORK=BEP20

# Tỷ giá mặc định; admin có thể đổi lúc chạy bằng /setrate.
USDT_VND_RATE=26500

# Không đặt dưới 15 giây để tránh rate limit.
BINANCE_POLL_INTERVAL=25

# Cảnh báo admin sau số lần poll Binance liên tiếp thất bại (tối thiểu 2).
BINANCE_POLL_FAIL_ALERT_THRESHOLD=5

# Đơn crypto chờ tối đa 30 phút.
CRYPTO_ORDER_TIMEOUT_SECONDS=1800

# Cửa sổ quét ngược mỗi lần poll (giây). Đủ rộng để bắt deposit confirm chậm và
# bù thời gian bot chết. Mặc định = max(CRYPTO_ORDER_TIMEOUT_SECONDS, 3600).
# BINANCE_POLL_LOOKBACK_SECONDS=3600

# Trần quét ngược khi bot chết lâu rồi bật lại (giây). Mặc định 24 giờ.
# BINANCE_POLL_MAX_LOOKBACK_SECONDS=86400
